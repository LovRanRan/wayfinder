TAVILY_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
OPENAI_API_KEY=

# Optional runtime modes.
# Keep deterministic defaults for unit tests and public smoke runs.
WAYFINDER_LLM_ROUTING=off
WAYFINDER_FINAL_WRITER=deterministic
WAYFINDER_COMMUNITY_CONTEXT=off
WAYFINDER_OPENAI_MODEL=gpt-5.5

# Optional user workspace mode.
# Run store backend: memory | sqlite | postgres.
#   sqlite   -> single-instance; set WAYFINDER_RUN_STORE_PATH to a persistent volume.
#   postgres -> horizontally scalable; set WAYFINDER_DATABASE_URL (needs the
#               'postgres' extra: uv sync --extra postgres).
WAYFINDER_REQUIRE_AUTH=0
WAYFINDER_RUN_STORE=memory
WAYFINDER_RUN_STORE_PATH=
WAYFINDER_DATABASE_URL=
WAYFINDER_SESSION_TTL_DAYS=30
WAYFINDER_KEY_ENCRYPTION_SECRET=

# Optional sandbox worker gate.
# Keep placeholder in public deploys unless a separate sandbox worker is live.
WAYFINDER_VERIFIER_RUNNER=placeholder
WAYFINDER_TEST_SANDBOX_URL=
WAYFINDER_TEST_SANDBOX_HEALTH=

# Optional public GitHub repo mode.
WAYFINDER_ENABLE_GITHUB_INGESTION=0
WAYFINDER_GITHUB_REPO_ALLOWLIST=langchain-ai/langchain,LovRanRan/wayfinder
WAYFINDER_GITHUB_MAX_FILES=10000
WAYFINDER_GITHUB_CACHE_ROOT=/tmp/wayfinder/repos

# Local filesystem repo ingestion allowlist (os.pathsep-separated roots).
# When auth is required and this is empty, local paths are denied and only
# cloned GitHub repos are readable, preventing arbitrary server-file reads.
WAYFINDER_LOCAL_REPO_ROOTS=

# Enterprise hardening (all optional; safe no-op defaults).
# CORS: comma-separated allowed browser origins for split-service deploys.
WAYFINDER_CORS_ALLOW_ORIGINS=
# Per-process request cap; 0 or empty disables app-level rate limiting.
WAYFINDER_RATE_LIMIT_PER_MINUTE=0
# Structured logs: set to "json" for machine-parseable access logs.
WAYFINDER_LOG_FORMAT=text
WAYFINDER_LOG_LEVEL=INFO
