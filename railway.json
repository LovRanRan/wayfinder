{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.api",
    "watchPatterns": [
      "src/**",
      "tests/**",
      "pyproject.toml",
      "uv.lock",
      "Dockerfile.api",
      "railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
